# Local Postgres for dev — run `docker compose up -d` (see docker-compose.yml), then use:
DATABASE_URL="postgresql://habits:habits@localhost:5433/habits?schema=public"

# For production, point this at Supabase (or wherever Postgres is hosted) instead:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Supabase project URL (Project Settings → API → Project URL), e.g. https://xxxxxxxx.supabase.co
# Used to build the JWKS endpoint for verifying Supabase-issued JWTs.
SUPABASE_URL="https://xxxxxxxx.supabase.co"

# Expected `aud` claim on Supabase JWTs — "authenticated" for logged-in users (Supabase default).
SUPABASE_JWT_AUDIENCE="authenticated"

PORT=3001

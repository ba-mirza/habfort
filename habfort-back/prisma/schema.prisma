// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User.id intentionally has no @default — it must equal the Supabase
// auth.users.id (JWT `sub` claim), so authenticated requests map 1:1
// to rows without a second identity system.
model User {
  id        String   @id
  email     String?  @unique
  createdAt DateTime @default(now())

  walletTransactions WalletTransaction[]
}

enum WalletSourceType {
  HABIT_COMPLETION
  FULL_BONUS
  REDEEM
}

model WalletTransaction {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  amount     Int
  sourceType WalletSourceType
  // HabitHistory.id | DailyBonusLog.id | Redeem.id | HabitLog.id (reversal) — added once those models exist
  sourceId   String?
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([sourceType, sourceId])
}

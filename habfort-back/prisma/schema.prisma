// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User.id intentionally has no @default — it must equal the Supabase
// auth.users.id (JWT `sub` claim), so authenticated requests map 1:1
// to rows without a second identity system.
model User {
  id        String   @id
  email     String?  @unique
  createdAt DateTime @default(now())

  walletTransactions WalletTransaction[]
  habits             Habit[]
}

enum HabitType {
  INSTANT
  CONDITIONAL
  RECURRING
}

enum HabitDifficulty {
  EASY
  MEDIUM
  HARD
}

enum HabitStatus {
  ACTIVE
}

enum RecurringScheduleType {
  DAILY
  DAYS_OF_WEEK
}

model Habit {
  id           String                 @id @default(uuid())
  userId       String
  user         User                   @relation(fields: [userId], references: [id])
  name         String
  type         HabitType
  difficulty   HabitDifficulty
  requiredDays Int? // conditional only
  scheduleType RecurringScheduleType? // recurring only
  scheduleDays Int[]                  @default([]) // recurring + DAYS_OF_WEEK only (0=Sun..6=Sat)
  status       HabitStatus            @default(ACTIVE)
  createdAt    DateTime               @default(now())

  logs HabitLog[]

  @@index([userId])
  @@index([userId, type])
}

model HabitLog {
  id        String   @id @default(uuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
}

enum WalletSourceType {
  HABIT_COMPLETION
  FULL_BONUS
  REDEEM
}

model WalletTransaction {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  amount     Int
  sourceType WalletSourceType
  // HabitHistory.id | DailyBonusLog.id | Redeem.id | HabitLog.id (reversal) — added once those models exist
  sourceId   String?
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([sourceType, sourceId])
}
